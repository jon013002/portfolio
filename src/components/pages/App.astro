---
const { currentLocale } = Astro
import { getI18N } from "@/i18n"

import SectionContainer from "@/components/SectionContainer.astro";
import Layout from "@/layouts/Layout.astro";

import HeroSection from "@/components/sections/HeroSection.astro";
import AboutMeSection from "@/components/sections/AboutMeSection.astro";
import SkillsSection from "@/components/sections/SkillsSection.astro";
import ProjectSection from "@/components/sections/ProjectSection.astro";

const i18n = getI18N({ currentLocale })
---
<Layout title=`${i18n.HERO_TITLE}` description="hola">
    <SectionContainer id="home">
        <HeroSection />
    </SectionContainer>

    <SectionContainer id="about-me" class="md:max-w-2xl lg:max-w-4xl">
        <AboutMeSection />
    </SectionContainer>

    <SectionContainer id="skills" class="md:max-w-2xl lg:max-w-4xl">
        <SkillsSection />
    </SectionContainer>

    <SectionContainer id="projects">
        <ProjectSection />
    </SectionContainer>
</Layout>