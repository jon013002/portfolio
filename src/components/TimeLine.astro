---
const { currentLocale } = Astro
import { getI18N } from "@/i18n"

const i18n = getI18N({ currentLocale })

---

<ol class="relative border-s border-purple-heart-400">
    {
        i18n.TIMELIINE.ITEMS.map((item) => (
        <li class="mb-10 ms-4">
            <div class="absolute w-3 h-3 bg-purple-heart-400 rounded-full mt-1.5 -start-1.5" />

            <span class="text-purple-heart-400 text-sm leading-none">{item.DATE} </span>

            <h3 class="text-lg font-semibold text-heading my-2">{item.EDUCATION_LEVEL}</h3>

            <p class="text-sm font-normal">{item.SCHOOL}</p>
        </li>
        ))
    }
</ol>
